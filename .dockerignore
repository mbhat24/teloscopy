# =============================================================================
# Teloscopy – Docker Ignore
# =============================================================================
# Files and directories excluded from the Docker build context to keep the
# image small and avoid leaking secrets.
# =============================================================================

# ---- Version control ----
.git
.gitignore

# ---- CI / IDE ----
.github
.vscode
.idea
*.code-workspace

# ---- Python artefacts ----
__pycache__
*.py[cod]
*.pyo
*.egg-info
*.egg
dist
build
wheels
.eggs

# ---- Virtual environments ----
.venv
venv
env
ENV

# ---- Testing & quality ----
.pytest_cache
.ruff_cache
.mypy_cache
.coverage
htmlcov
.tox
.nox

# ---- Environment & secrets ----
.env
.env.local
.env.*.local
*.pem
*.key

# ---- OS junk ----
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ---- Docker (avoid recursive context) ----
Dockerfile
docker-compose*.yml
.dockerignore

# ---- Documentation & misc ----
docs
*.md
LICENSE
CHANGELOG*
Makefile

# ---- Data & output (mounted at runtime via volumes) ----
data
output
logs
*.fasta
*.fastq
*.bam
*.sam
