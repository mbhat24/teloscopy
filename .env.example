# =============================================================================
# Teloscopy – Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment:
#   cp .env.example .env
#
# All variables are optional – sensible defaults are used when unset.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
# Environment: development | staging | production
TELOSCOPY_ENV=development

# Secret key for session signing (generate with: python -c "import secrets; print(secrets.token_hex(32))")
# TELOSCOPY_SECRET_KEY=change-me-in-production

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
TELOSCOPY_HOST=0.0.0.0
TELOSCOPY_PORT=8000
# Number of uvicorn worker processes (production only; 1 is fine for dev)
# TELOSCOPY_WORKERS=4

# ---------------------------------------------------------------------------
# File Storage
# ---------------------------------------------------------------------------
TELOSCOPY_UPLOAD_DIR=./data/uploads
TELOSCOPY_OUTPUT_DIR=./output
TELOSCOPY_MAX_UPLOAD_SIZE=50MB

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Level: DEBUG | INFO | WARNING | ERROR | CRITICAL
TELOSCOPY_LOG_LEVEL=INFO
# TELOSCOPY_LOG_FILE=./logs/teloscopy.log

# ---------------------------------------------------------------------------
# Analysis Defaults
# ---------------------------------------------------------------------------
# Default telomere repeat motif
# TELOSCOPY_TELOMERE_MOTIF=TTAGGG
# Minimum sequence length to accept (bp)
# TELOSCOPY_MIN_SEQ_LENGTH=100

# ---------------------------------------------------------------------------
# Database (if applicable)
# ---------------------------------------------------------------------------
# TELOSCOPY_DATABASE_URL=sqlite:///./data/teloscopy.db

# ---------------------------------------------------------------------------
# CORS (comma-separated origins allowed to call the API)
# ---------------------------------------------------------------------------
# TELOSCOPY_CORS_ORIGINS=http://localhost:3000,http://localhost:8000
